<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width,initial-scale=1.0">

<title>ACHEX TECH HUB</title>

<meta name="theme-color" content="#050505">

<meta name="description"
content="Achex Tech Hub | Built For Performance • Chosen For You">

<link rel="preconnect"
href="https://fonts.googleapis.com">

<link rel="preconnect"
href="https://fonts.gstatic.com"
crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
rel="stylesheet">

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

<style>

*{

margin:0;

padding:0;

box-sizing:border-box;

font-family:'Poppins',sans-serif;

}

html{

scroll-behavior:smooth;

}

body{

background:#030303;

color:#fff;

min-height:100vh;

display:flex;

justify-content:center;

align-items:center;

padding:20px;

overflow-x:hidden;

position:relative;

}
   /* ===========================
FUTURISTIC TECH BACKGROUND
=========================== */

body::before{

content:"";

position:fixed;

inset:0;

background:

radial-gradient(circle at 18% 20%,rgba(61,213,255,.10),transparent 28%),

radial-gradient(circle at 82% 22%,rgba(255,215,0,.08),transparent 30%),

radial-gradient(circle at 50% 85%,rgba(61,213,255,.06),transparent 35%);

filter:blur(90px);

animation:aurora 18s linear infinite;

z-index:-5;

}

@keyframes aurora{

0%{
transform:rotate(0deg) scale(1);
}

50%{
transform:rotate(180deg) scale(1.15);
}

100%{
transform:rotate(360deg) scale(1);
}

}

/* Circuit Board Grid */

body::after{

content:"";

position:fixed;

inset:0;

background-image:

linear-gradient(rgba(61,213,255,.05) 1px,transparent 1px),

linear-gradient(90deg,rgba(61,213,255,.05) 1px,transparent 1px);

background-size:42px 42px;

opacity:.35;

pointer-events:none;

z-index:-4;

}

/* Floating Tech Particles */

.particle{

position:fixed;

width:4px;

height:4px;

border-radius:50%;

background:#3dd5ff;

box-shadow:0 0 12px #3dd5ff;

animation:floatParticle linear infinite;

pointer-events:none;

z-index:-3;

}

.particle.gold{

background:#ffd700;

box-shadow:0 0 12px #ffd700;

}

@keyframes floatParticle{

0%{

transform:translateY(110vh);

opacity:0;

}

10%{

opacity:1;

}

90%{

opacity:1;

}

100%{

transform:translateY(-20vh);

opacity:0;

}

/* ===========================
MAIN CARD
=========================== */

.card{

width:100%;

max-width:440px;

padding:30px 24px;

border-radius:32px;

background:rgba(255,255,255,.06);

backdrop-filter:blur(24px);

border:1px solid rgba(255,255,255,.10);

box-shadow:

0 25px 70px rgba(0,0,0,.75),

0 0 30px rgba(61,213,255,.08);

position:relative;

overflow:hidden;

animation:cardIn .8s ease;

}

/* Glass Reflection */

.card::before{

content:"";

position:absolute;

top:-150%;

left:-60%;

width:70%;

height:300%;

background:linear-gradient(

90deg,

transparent,

rgba(255,255,255,.08),

transparent

);

transform:rotate(25deg);

animation:shine 8s infinite;

pointer-events:none;

}

@keyframes shine{

0%{

left:-80%;

}

100%{

left:180%;

}

}

@keyframes cardIn{

from{

opacity:0;

transform:translateY(35px);

}

to{

opacity:1;

transform:translateY(0);

}

}
   }
   /* ===========================
TOP SECTION
=========================== */

.top{

text-align:center;

position:relative;

z-index:2;

}

.logo-ring{

width:140px;

height:140px;

margin:auto;

padding:4px;

border-radius:50%;

background:linear-gradient(135deg,#3dd5ff,#ffd700);

box-shadow:

0 0 25px rgba(61,213,255,.35),

0 0 25px rgba(255,215,0,.18);

}

.logo-inner{

width:100%;

height:100%;

padding:5px;

border-radius:50%;

background:#080808;

}

.profile{

width:100%;

height:100%;

border-radius:50%;

object-fit:cover;

display:block;

}

h1{

margin-top:22px;

font-size:30px;

font-weight:800;

letter-spacing:1px;

background:linear-gradient(90deg,#ffffff,#ffd700);

-webkit-background-clip:text;

-webkit-text-fill-color:transparent;

}

.tagline{

margin-top:8px;

font-size:14px;

font-weight:500;

color:#cfcfcf;

letter-spacing:.4px;

}

.location{

margin-top:16px;

display:flex;

justify-content:center;

align-items:center;

gap:8px;

font-size:13px;

color:#d7d7d7;

}

.location i{

color:#ff5b5b;

}

.status{

margin-top:16px;

display:inline-flex;

align-items:center;

gap:10px;

padding:11px 18px;

border-radius:999px;

background:rgba(255,255,255,.05);

border:1px solid rgba(255,255,255,.08);

font-size:13px;

font-weight:500;

}

.status .dot{

width:8px;

height:8px;

border-radius:50%;

background:#22ff66;

box-shadow:0 0 12px #22ff66;

animation:pulse 1.5s infinite;

}

@keyframes pulse{

0%{

transform:scale(1);

opacity:1;

}

50%{

transform:scale(1.6);

opacity:.5;

}

100%{

transform:scale(1);

opacity:1;

}

}

.premium-divider{

width:100%;

height:2px;

margin:26px 0;

border-radius:999px;

background:linear-gradient(

90deg,

transparent,

rgba(61,213,255,.5),

rgba(255,215,0,.5),

transparent

);

box-shadow:

0 0 10px rgba(61,213,255,.2);

}
   /* ===========================
CONTACT SECTION
=========================== */

.contact-section{

display:flex;

align-items:flex-start;

justify-content:space-between;

gap:16px;

margin-top:28px;

}

/* QR */

.qr-box{

width:135px;

flex-shrink:0;

display:flex;

flex-direction:column;

align-items:center;

}

.qr-frame{

position:relative;

padding:10px;

background:#fff;

border-radius:20px;

box-shadow:

0 0 18px rgba(61,213,255,.25),

0 0 30px rgba(61,213,255,.08);

transition:.35s;

}

.qr-frame:hover{

transform:translateY(-4px);

box-shadow:

0 0 28px rgba(61,213,255,.45);

}

.qr-frame img{

width:115px;

height:115px;

display:block;

border-radius:10px;

}

.corner{

position:absolute;

width:16px;

height:16px;

border:3px solid #3dd5ff;

}

.tl{

top:-4px;

left:-4px;

border-right:none;

border-bottom:none;

}

.tr{

top:-4px;

right:-4px;

border-left:none;

border-bottom:none;

}

.bl{

bottom:-4px;

left:-4px;

border-right:none;

border-top:none;

}

.br{

bottom:-4px;

right:-4px;

border-left:none;

border-top:none;

}

.scan-text{

margin-top:12px;

font-size:10px;

letter-spacing:3px;

font-weight:700;

color:#d8d8d8;

}

/* CONTACTS */

.contact-info{

flex:1;

display:flex;

flex-direction:column;

gap:14px;

}

/* PHONE BOX */

.phone-box{

background:rgba(255,255,255,.05);

border:1px solid rgba(255,255,255,.08);

border-left:3px solid #3dd5ff;

border-radius:18px;

overflow:hidden;

backdrop-filter:blur(10px);

}

.phone-row{

display:flex;

align-items:center;

gap:14px;

padding:15px;

text-decoration:none;

color:#fff;

transition:.3s;

}

.phone-row:hover{

background:rgba(61,213,255,.08);

}

.phone-divider{

height:1px;

background:rgba(255,255,255,.08);

margin:0 15px;

}

/* EMAIL BOX */

.email-box{

display:flex;

align-items:center;

gap:14px;

padding:15px;

border-radius:18px;

background:rgba(255,215,0,.06);

border:1px solid rgba(255,215,0,.18);

border-left:3px solid #ffd700;

text-decoration:none;

color:#fff;

transition:.3s;

}

.email-box:hover{

background:rgba(255,215,0,.10);

}

/* ICONS */

.phone-icon{

color:#3dd5ff;

font-size:20px;

width:24px;

text-align:center;

}

.email-icon{

color:#ffd700;

font-size:20px;

width:24px;

text-align:center;

}

.label{

font-size:12px;

font-weight:600;

opacity:.65;

}

.value{

font-size:14px;

font-weight:500;

}

/* ===========================
PHONE RESPONSIVE
(KEEP SIDE BY SIDE)
=========================== */

@media(max-width:600px){

.contact-section{

display:flex;

flex-direction:row;

align-items:flex-start;

gap:12px;

}

.qr-box{

width:120px;

}

.qr-frame img{

width:100px;

height:100px;

}

.contact-info{

flex:1;

}

.value{

font-size:12px;

}

.label{

font-size:11px;

}

}
   /* ===========================
FOLLOW US
=========================== */

.follow{

display:flex;

align-items:center;

gap:14px;

margin:30px 0 22px;

}

.follow .line{

flex:1;

height:2px;

border-radius:999px;

background:linear-gradient(
90deg,
transparent,
rgba(61,213,255,.50),
rgba(255,215,0,.50),
transparent
);

box-shadow:0 0 10px rgba(61,213,255,.18);

}

.follow .text{

font-size:11px;

font-weight:700;

letter-spacing:3px;

color:#d6d6d6;

white-space:nowrap;

}

/* ===========================
SOCIAL ICONS
=========================== */

.socials{

display:flex;

justify-content:center;

gap:16px;

margin-bottom:28px;

}

.socials a{

width:52px;

height:52px;

display:flex;

justify-content:center;

align-items:center;

text-decoration:none;

border-radius:18px;

background:rgba(255,255,255,.05);

border:1px solid rgba(255,255,255,.08);

backdrop-filter:blur(12px);

font-size:22px;

transition:.35s ease;

position:relative;

overflow:hidden;

}

.socials a::before{

content:"";

position:absolute;

width:100%;

height:100%;

background:linear-gradient(
135deg,
transparent,
rgba(255,255,255,.12),
transparent
);

transform:translateX(-120%);

transition:.5s;

}

.socials a:hover::before{

transform:translateX(120%);

}

.socials a:hover{

transform:translateY(-6px) scale(1.08);

box-shadow:0 0 20px rgba(61,213,255,.25);

}

.fa-facebook-f{color:#1877F2;}
.fa-whatsapp{color:#25D366;}

.fa-instagram{

background:linear-gradient(
45deg,
#f09433,
#e6683c,
#dc2743,
#bc1888);

-webkit-background-clip:text;

-webkit-text-fill-color:transparent;

}

.fa-x-twitter{

color:#ffffff;

}

.fa-tiktok{

color:#ffffff;

}

/* ===========================
BUTTONS
=========================== */

.btn-row{

display:flex;

gap:12px;

margin-bottom:26px;

}

.btn{

flex:1;

padding:15px;

border-radius:16px;

font-size:14px;

font-weight:700;

cursor:pointer;

transition:.35s;

}

/* Soft Blue (V2 Style) */

.save-btn{

background:rgba(61,213,255,.10);

border:1px solid rgba(61,213,255,.30);

color:#3dd5ff;

backdrop-filter:blur(12px);

}

.save-btn:hover{

background:rgba(61,213,255,.16);

transform:translateY(-3px);

box-shadow:0 0 18px rgba(61,213,255,.25);

}

/* Soft Gold (V2 Style) */

.share-btn{

background:rgba(255,215,0,.10);

border:1px solid rgba(255,215,0,.30);

color:#ffd700;

backdrop-filter:blur(12px);

}

.share-btn:hover{

background:rgba(255,215,0,.16);

transform:translateY(-3px);

box-shadow:0 0 18px rgba(255,215,0,.20);

}

/* ===========================
FOOTER
=========================== */

.footer{

padding-top:18px;

border-top:1px solid rgba(255,255,255,.06);

text-align:center;

font-size:12px;

color:#9f9f9f;

line-height:1.8;

}

/* ===========================
TOAST
=========================== */

#toast{

position:fixed;

left:50%;

bottom:25px;

transform:translateX(-50%);

padding:12px 24px;

border-radius:12px;

background:#101010;

border:1px solid rgba(255,255,255,.08);

opacity:0;

transition:.3s;

z-index:999;

}

#toast.show{

opacity:1;

}

/* ===========================
END CSS
=========================== */

</style>

</head>
<body>

<div class="card">

<div class="top">

<div class="logo-ring">

<div class="logo-inner">

<img src="profile.png" class="profile" alt="Achex Tech Hub">

</div>

</div>

<h1>ACHEX TECH HUB</h1>

<p class="tagline">

Built For Performance • Chosen For You

</p>

<div class="location">

<i class="fa-solid fa-location-dot"></i>

<span>Embu, Kenya</span>

</div>

<div class="status">

<span class="dot"></span>

Open for Business

</div>

<div class="premium-divider"></div>

</div>

<!-- CONTACT SECTION -->

<div class="contact-section">

<!-- QR -->

<div class="qr-box">

<div class="qr-frame">

<span class="corner tl"></span>
<span class="corner tr"></span>
<span class="corner bl"></span>
<span class="corner br"></span>

<img src="https://api.qrserver.com/v1/create-qr-code/?size=500x500&data=https://achexhub.github.io/achex-tech-hub/" alt="QR Code">

</div>

<div class="scan-text">

SCAN TO VISIT

</div>

</div>

<!-- CONTACTS -->

<div class="contact-info">

<!-- PHONE BOX -->

<div class="phone-box">

<a class="phone-row" href="tel:+254706056515">

<i class="fa-solid fa-mobile-screen-button phone-icon"></i>

<div>

<div class="label">

Phone

</div>

<div class="value">

+254 706 056 515

</div>

</div>

</a>

<div class="phone-divider"></div>

<a class="phone-row" href="tel:+254704817217">

<i class="fa-solid fa-mobile-screen-button phone-icon"></i>

<div>

<div class="label">

Phone

</div>

<div class="value">

+254 704 817 217

</div>

</div>

</a>

</div>

<!-- EMAIL -->

<a class="email-box"

href="mailto:achexhub@gmail.com">

<i class="fa-solid fa-envelope email-icon"></i>

<div>

<div class="label">

Email

</div>

<div class="value">

achexhub@gmail.com

</div>

</div>

</a>

</div>

</div>

<!-- FOLLOW -->

<div class="follow">

<div class="line"></div>

<div class="text">

FOLLOW US

</div>

<div class="line"></div>

</div>

<!-- SOCIALS -->

<div class="socials">

<a href="https://www.facebook.com/cee.jay.355500"
   target="_blank"
   rel="noopener noreferrer"
   title="Facebook">

    <i class="fab fa-facebook-f"></i>

</a>

<a href="https://wa.me/254706056515" title="WhatsApp">

<i class="fab fa-whatsapp"></i>

</a>

<a href="https://instagram.com/achex_tech_ke" title="Instagram">

<i class="fab fa-instagram"></i>

</a>

<a href="https://x.com/achextech" title="X">

<i class="fab fa-x-twitter"></i>

</a>

<a href="https://vm.tiktok.com/ZS9jQc9FystjS-6hX4l/" title="TikTok">

<i class="fab fa-tiktok"></i>

</a>

</div>

<!-- BUTTONS -->

<div class="btn-row">

<button class="btn save-btn"

onclick="downloadVCF()">

📇 Save Contact

</button>

<button class="btn share-btn"

onclick="shareCard()">

🔗 Share Card

</button>

</div>

<div class="footer">

Powered by <strong>Achex Tech Hub</strong>

<br>

Built For Performance • Chosen For You

</div>

</div>

<div id="toast"></div>
<script>

/* ===========================
CREATE FLOATING PARTICLES
=========================== */

const particleColors=["","gold"];

for(let i=0;i<35;i++){

const p=document.createElement("div");

p.className="particle";

if(Math.random()>.5){

p.classList.add("gold");

}

p.style.left=Math.random()*100+"vw";

p.style.animationDuration=(10+Math.random()*12)+"s";

p.style.animationDelay=(Math.random()*12)+"s";

p.style.opacity=Math.random();

document.body.appendChild(p);

}

/* ===========================
TOAST
=========================== */

function showToast(message){

const toast=document.getElementById("toast");

toast.innerHTML=message;

toast.classList.add("show");

setTimeout(()=>{

toast.classList.remove("show");

},2200);

}

/* ===========================
SAVE CONTACT
=========================== */

function downloadVCF(){

const card=`BEGIN:VCARD
VERSION:3.0
FN:Achex Tech Hub
ORG:Achex Tech Hub
TEL:+254706056515
TEL:+254704817217
EMAIL:achexhub@gmail.com
ADR:Embu, Kenya
URL:https://achexhub.github.io/achex-tech-hub/
END:VCARD`;

const blob=new Blob([card],{type:"text/vcard"});

const link=document.createElement("a");

link.href=URL.createObjectURL(blob);

link.download="Achex-Tech-Hub.vcf";

link.click();

showToast("✔ Contact Saved");

}

/* ===========================
SHARE CARD
=========================== */

async function shareCard(){

const shareData={

title:"Achex Tech Hub",

text:"Built For Performance • Chosen For You",

url:"https://achexhub.github.io/achex-tech-hub/"

};

if(navigator.share){

try{

await navigator.share(shareData);

}catch(e){}

}else{

navigator.clipboard.writeText(shareData.url);

showToast("✔ Link Copied");

}

}

</script>

</body>

</html>
