<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Achex Tech Hub</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0d0d0d;
      color: #fff;
      text-align: center;
    }

    .container {
      padding: 40px 20px;
      max-width: 600px;
      margin: auto;
    }

    .profile-pic {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      border: 3px solid gold;
      object-fit: cover;
    }

    h1 {
      margin: 15px 0 5px;
      color: gold;
      font-size: 28px;
    }

    p {
      color: #ccc;
      margin-bottom: 25px;
    }

    .btn {
      display: block;
      width: 85%;
      max-width: 320px;
      margin: 12px auto;
      padding: 14px;
      border-radius: 10px;
      text-decoration: none;
      color: black;
      background: gold;
      font-weight: bold;
      transition: 0.3s;
    }

    .btn:hover {
      background: #d4af37;
      transform: scale(1.02);
    }

    .section-title {
      margin-top: 35px;
      color: gold;
      font-size: 14px;
      letter-spacing: 2px;
    }

    /* SOCIAL ICONS */
    .socials {
      margin-top: 15px;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 14px;
    }

    .socials a img {
      width: 42px;
      height: 42px;
      transition: 0.3s;
    }

    .socials a img:hover {
      transform: scale(1.2);
    }

    footer {
      margin-top: 40px;
      font-size: 12px;
      color: #666;
    }

  </style>
</head>

<body>

  <div class="container">

    <!-- PROFILE -->
    <img class="profile-pic" src="https://via.placeholder.com/120" alt="Profile">
    
    <h1>Achex Tech Hub</h1>
    <p>Smart Tech Solutions | Sales & Support</p>

    <!-- CONTACT SECTION -->
    <a class="btn" href="https://wa.me/254712345678" target="_blank">📞 WhatsApp Contact</a>
    <a class="btn" href="https://wa.me/254712345678" target="_blank">💬 WhatsApp Business</a>
    <a class="btn" href="mailto:achextechhub@gmail.com">📧 Email Us</a>

    <!-- SOCIAL TITLE -->
    <div class="section-title">FOLLOW US</div>

    <!-- SOCIAL ICONS -->
    <div class="socials">

      <a href="https://instagram.com/yourusername" target="_blank">
        <img src="https://cdn-icons-png.flaticon.com/512/2111/2111463.png" alt="Instagram">
      </a>

      <a href="https://tiktok.com/@yourusername" target="_blank">
        <img src="https://cdn-icons-png.flaticon.com/512/3046/3046126.png" alt="TikTok">
      </a>

      <a href="https://facebook.com/yourpage" target="_blank">
        <img src="https://cdn-icons-png.flaticon.com/512/733/733547.png" alt="Facebook">
      </a>

      <a href="https://x.com/yourusername" target="_blank">
        <img src="https://cdn-icons-png.flaticon.com/512/733/733579.png" alt="Twitter">
      </a>

      <a href="https://linkedin.com/in/yourprofile" target="_blank">
        <img src="https://cdn-icons-png.flaticon.com/512/145/145807.png" alt="LinkedIn">
      </a>

    </div>

    <footer>
      © 2026 Achex Tech Hub. All Rights Reserved.
    </footer>

  </div>

</body>
</html>
